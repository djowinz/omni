{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omni.local/contracts/bundle-manifest.schema.json",
  "title": "Omni Bundle Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "version",
    "omni_min_version",
    "description",
    "tags",
    "license",
    "entry_overlay",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 64 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[\\w\\.-]+)?$"
    },
    "omni_min_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": { "type": "string", "maxLength": 280 },
    "tags": {
      "type": "array",
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "dark", "light", "minimal", "gaming", "neon", "retro",
          "cyberpunk", "pastel", "high-contrast", "monospace",
          "racing", "flightsim", "mmo", "fps", "productivity", "creative"
        ]
      }
    },
    "license": { "type": "string", "maxLength": 64 },
    "entry_overlay": { "type": "string", "pattern": "^[\\w.-]+\\.omni$" },
    "default_theme": {
      "type": "string",
      "pattern": "^themes/[\\w.-]+\\.css$"
    },
    "sensor_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 256 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "signature": { "type": "string", "pattern": "^[0-9a-f]{128}$" }
  }
}
