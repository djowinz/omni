# Build file ignores
dist/
target/
apps/desktop/renderer/generated/
node_modules/
.next/
*.tsbuildinfo

# secrets ignore
secrets/
.env
.env.*
*.pem
*.key

# AI tool ignores
.claude/
.cursor/
.vscode/ai_history
.windsurf/
.anthropic/
.continue/
mcp_config.json

# Ignore any AI tool artificats
docs/superpowers
.worktrees/
.superpowers

# Any documents for frontend
apps/desktop/docs

# Worker service secrets
services/**/.dev.vars

# Wrangler Cache
.wrangler

# Worker WASM build outputs
services/omni-themes-worker/src/wasm/*.wasm
services/omni-themes-worker/src/wasm/*.js
services/omni-themes-worker/src/wasm/*.d.ts

# Worker test fixtures (regenerated from seed; never commit binaries)
services/omni-themes-worker/test/fixtures/*.omnipkg
services/omni-themes-worker/test/fixtures/fixtures.json
