# Build file ignores
dist/
target/
apps/desktop/renderer/generated/
node_modules/
**/node_modules/
packages/*/dist/
.next/
*.tsbuildinfo

# secrets ignore
secrets/
.env
.env.*
*.pem
*.key

# AI tool ignores
.claude/
.cursor/
.vscode/ai_history
.windsurf/
.anthropic/
.continue/
mcp_config.json

# Ignore any AI tool artificats
docs/superpowers
.worktrees/
.superpowers

# Any documents for frontend
apps/desktop/docs

# Worker service secrets
services/**/.dev.vars

# Cloudflare Worker
apps/worker/.wrangler/

# Wrangler Cache
.wrangler

# wasm-pack output directories (built under each WASM crate during deploy)
crates/*/pkg/

# Worker WASM build outputs
apps/worker/src/wasm/*.wasm
apps/worker/src/wasm/*.js
apps/worker/src/wasm/*.d.ts

# Worker test fixtures (regenerated from seed; never commit binaries)
apps/worker/test/fixtures/*.omnipkg
apps/worker/test/fixtures/fixtures.json

# Dev loop fixtures — per-machine synthetic author keypairs (see docs/superpowers/specs/2026-04-18-local-dev-worker-design.md)
apps/worker/seed/dev-fixtures/

# Old (deleted) paths — prevent accidental resurrection
/default/
/services/
