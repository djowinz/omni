{
  "name": "omni-themes-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker backend for Omni theme & bundle sharing (skeleton).",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply META --local",
    "migrate:remote": "wrangler d1 migrations apply META --remote"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20260401.0",
    "@hono/zod-validator": "^0.4.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.0",
    "zod": "^3.23.0"
  }
}
